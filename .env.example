# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/vaigai-tourism

# ─── Email (Gmail SMTP) ───────────────────────────────────────────────────────
# The Gmail account used to SEND emails (can be same as admin)
EMAIL_USER=vaigaitourism@gmail.com
# Generate at: Google Account → Security → 2-Step Verification → App Passwords
EMAIL_PASS=your_gmail_app_password_here

# Admin email is hardcoded in booking.js as vaigaitourism@gmail.com
# Change it there if needed
